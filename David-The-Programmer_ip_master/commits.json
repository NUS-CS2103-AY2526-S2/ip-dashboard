en as an property of a command in a specific order.\n","tags":["A-FullCommitMessage"],"fileTypesAndContributionMap":{"java":{"insertions":315,"deletions":173}}}]},{"date":"2026-02-23T00:00:00","commitResults":[{"hash":"d90748915e20524020dc8682504ff732cf582a0a","isMergeCommit":false,"messageTitle":"Refactor datetime parsing","messageBody":"","fileTypesAndContributionMap":{"java":{"insertions":153,"deletions":93}}},{"hash":"9779fb74ea71191230e932434e1acc231f784cc3","isMergeCommit":false,"messageTitle":"Refactor TaskDeserialiser to use stream","messageBody":"","fileTypesAndContributionMap":{"java":{"insertions":147,"deletions":58}}},{"hash":"b2e7c379f6eb51e8dbdbac2b5d2ace34f8314381","isMergeCommit":false,"messageTitle":"Fix import order checkstyle errors","messageBody":"","fileTypesAndContributionMap":{"java":{"insertions":22,"deletions":17}}},{"hash":"0c56946697f0a8fe4a83f308aee0908231328aec","isMergeCommit":false,"messageTitle":"Fix all javadoc comments","messageBody":"","fileTypesAndContributionMap":{"java":{"insertions":368,"deletions":89}}},{"hash":"40cfcb865a139956cf4dd22f89c814677396d290","isMergeCommit":false,"messageTitle":"Fix all indentation errors","messageBody":"","fileTypesAndContributionMap":{"java":{"insertions":15,"deletions":16}}},{"hash":"3e04375793d04e352a9f9b63d70d9d442ecfef52","isMergeCommit":true,"messageTitle":"Merge pull request #2 from David-The-Programmer/branch-A-CodeQuality","messageBody":"Merge branch-A-CodeQuality changes into master branch","tags":["A-CodeQuality"],"fileTypesAndContributionMap":{}},{"hash":"aeb76b5be8833ac4465fb89f82884b3b519c7aa3","isMergeCommit":true,"messageTitle":"Resolve merge conflicts","messageBody":"","fileTypesAndContributionMap":{}},{"hash":"4debacd6ad535189f6c551cad16b22469cea87dc","isMergeCommit":false,"messageTitle":"Add original assert changes back","messageBody":"","fileTypesAndContributionMap":{"java":{"insertions":3,"deletions":0}}},{"hash":"229878ecb4f0381df32618c87349d16cd247b6ae","isMergeCommit":true,