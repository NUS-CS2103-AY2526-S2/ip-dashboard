dContributionMap":{"gradle":{"insertions":16,"deletions":1},"fxml":{"insertions":66,"deletions":0},"java":{"insertions":217,"deletions":34}}},{"hash":"0085af1040c62df4c56e24eada46c0631a3e39ed","isMergeCommit":false,"messageTitle":"Level-10","messageBody":"","fileTypesAndContributionMap":{"java":{"insertions":18,"deletions":24}}},{"hash":"ae7f3aa4a765c4df9b7f7a770837281d66c2d08e","isMergeCommit":false,"messageTitle":"Level-10","messageBody":"","fileTypesAndContributionMap":{"txt":{"insertions":1,"deletions":0},"java":{"insertions":12,"deletions":5}}},{"hash":"1084e3799bf1b8eb50e5563476958aa01d1d94df","isMergeCommit":false,"messageTitle":"Level-10","messageBody":"","fileTypesAndContributionMap":{"java":{"insertions":12,"deletions":0}}},{"hash":"befdd4640038018e5bd14c429848a81e46a9a609","isMergeCommit":false,"messageTitle":"Improved on coding quality","messageBody":"Deleted redundant methods, while trying to make some loops more enhanced or efficient.\n","tags":["A-FullCommitMessage","A-CodingQuality","A-Assertions"],"fileTypesAndContributionMap":{"txt":{"insertions":1,"deletions":0},"java":{"insertions":10,"deletions":19}}},{"hash":"8c79ea796a6498bd74c0aebdff98518a8e8fd7f2","isMergeCommit":true,"messageTitle":"Merge A-CodingQuality and A-Assertions","messageBody":"","fileTypesAndContributionMap":{}},{"hash":"a91d83d8a4db558a07fec3182ae781058334ad43","isMergeCommit":false,"messageTitle":"A-AiAssisted","messageBody":"","tags":["A-AiAssisted"],"fileTypesAndContributionMap":{"java":{"insertions":2,"deletions":0}}},{"hash":"87277e1050726028cd18c19ce3e44af1a3c5ad3e","isMergeCommit":false,"messageTitle":"A-UserGuide","messageBody":"","tags":["A-Release"],"fileTypesAndContributionMap":{"md":{"insertions":9,"deletions":22}}}]},{"date":"2026-02-24T00:00:00","commitResults":[{"hash":"6ee79fad4c24b0649384bbc45f13234020370f35","isMergeCommit":false,"messageTitle":"A-UserGuide","messageBody":"","fileTypesAndContributionMap":{"txt":{"insertions":1,"deletions":1}}},{"hash":"5ae94c69c8b217ff069cf50c0297420c76720045","isMergeCommit":false,"messageTitle":"TaskList: Reject duplicate tasks when adding tasks","messageBody":"Adding a task currently allows duplicate entries to be stored.\n\nDuplicates make the task list harder to manage and can confuse users.\n\nLet\u0027s check for an existing matching task before adding a new one and\nthrow an exception if a duplicate is found.\n\nThis keeps the task list consistent and prevents accidental duplicate\nentries.\n","fileTypesAndContributionMap":{"gradle":{"insertions":1,"deletions":1},"java":{"insertions":71,"deletions":2}}},{"hash":"f2e3144da37c518e03b3a0e239fd550bfba6a6bc","isMergeCommit":false,"messageTitle":"Add User Guide for Ploopy chatbot in GFM format","messageBody":"Create a user-facing guide for Ploopy covering setup, usage, and\nsupported commands. The guide includes quick start instructions for\nrunning the app via the JAR file, an overview of the GUI chat interface,\ncommand formats for todos, deadlines, and events, and a command summary\ntable.\n\nAlso document expected behavior for core actions (list, mark, unmark,\ndelete, bye), add FAQ and troubleshooting sections, and include a\nplaceholder/example for embedding a UI screenshot in the markdown.\n","fileTypesAndContributionMap":{"md":{"insertions":392,"deletions":14}}},{"hash":"d04360f872f30437ef16da6342d709cae5ba1d17","isMergeCommit":false,"messageTitle":"Set JavaFX window title to chatbot name","messageBody":"Update the main JavaFX application startup to set the Stage title to\n\"Ploopy\" so the chatbot name appears in the OS window title bar.\n\nThis improves the GUI presentation and makes the application easier to\nidentify when multiple windows are open, without changing the existing\nchat layout or interaction flow.\n","fileTypesAndContributionMap":{"java":{"insertions":1,"deletions":0}}},{"hash":"e12250d9464edfc42e6cff64771c27903311e4f4","isMergeCommit":false,"messageTitle":"Refactor FXML layout to support automatic GUI resizing","messageBody":"Update MainWindow.fxml to improve responsiveness by adjusting the layout\nand sizing behavior of UI components so they resize more consistently\nwith the application window.\n\nThis change reduces reliance on fixed positioning, improves visual\nalignment across different window sizes, and makes the chat interface\nmore robust for future UI updates.\n","fileTypesAndContributionMap":{"fxml":{"insertions":3,"deletions":20}}},{"hash":"a2a029fa19589efdf29e0e522e04bc7b05216add","isMergeCommit":false,"messageTitle":"Add CSS styling support for main window and dialog boxes","messageBody":"Update the JavaFX GUI to load separate stylesheet files for the main\nwindow and chat dialog components. Attach the stylesheets to the scene\nand apply style classes to the main layout and dialog box nodes so UI\nstyles can be managed consistently through CSS.\n\nThis improves the maintainability of the GUI code and makes it easier to\ncustomize the appearance of the chat interface without changing FXML or\nJava layout logic.\n","fileTypesAndContributionMap":{"fxml":{"insertions":1,"deletions":0},"java":{"insertions":14,"deletions":3}}},{"hash":"161385d15ff79a2a3063f57fd1b3e5b575d22ec1","isMergeCommit":false,"messageTitle":"Improve chat bubble alignment and spacing for cleaner GUI layout","messageBody":"Update the dialog box UI so chatbot responses are visually flipped to\nface the chatbot side, making the conversation flow clearer and more\nnatural to read. Refine the bubble alignment behavior to better\ndistinguish user messages from bot replies.\n\nAlso adjust dialog box padding and margins to improve spacing,\nreadability, and overall visual balance of the chat interface. These\nchanges make the GUI look more polished without affecting chatbot\nfunctionality.\n","fileTypesAndContributionMap":{"java":{"insertions":1,"deletions":0}}}]}]},"authorFileTypeContributionMap":{"desnen":{"java":1342,"md":398,"fxml":50,"sh":0,"bat":0,"gradle":24,"txt":7}},"authorContributionVariance":{"desnen":33931.77},"authorDisplayNameMap":{"desnen":"CS2103T-T08-4 TOH .. YEE"}}
